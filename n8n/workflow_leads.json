{
  "name": "IAtria - Triagem Inteligente de Leads",
  "nodes": [
    {
      "parameters": {
        "path": "iatria-leads",
        "httpMethod": "POST",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "1",
      "name": "Webhook Leads",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [220, 300]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "name": "nome",
              "type": "string",
              "value": "={{ $json.body?.nome ?? $json.nome }}"
            },
            {
              "name": "email",
              "type": "string",
              "value": "={{ $json.body?.email ?? $json.email }}"
            },
            {
              "name": "mensagem",
              "type": "string",
              "value": "={{ $json.body?.mensagem ?? $json.mensagem }}"
            }
          ]
        },
        "options": {}
      },
      "id": "2",
      "name": "Normalizar Lead",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [460, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.TRIAGEM_API_URL || \"http://localhost:8000/triagem\" }}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json }}",
        "options": {
          "timeout": 15000
        }
      },
      "id": "3",
      "name": "Triagem Backend",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [700, 300]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "name": "nome",
              "type": "string",
              "value": "={{ $(\"Normalizar Lead\").first().json.nome }}"
            },
            {
              "name": "email",
              "type": "string",
              "value": "={{ $(\"Normalizar Lead\").first().json.email }}"
            },
            {
              "name": "mensagem",
              "type": "string",
              "value": "={{ $(\"Normalizar Lead\").first().json.mensagem }}"
            },
            {
              "name": "intent",
              "type": "string",
              "value": "={{ $(\"Triagem Backend\").first().json.intent }}"
            },
            {
              "name": "sentiment",
              "type": "string",
              "value": "={{ $(\"Triagem Backend\").first().json.sentiment }}"
            },
            {
              "name": "fallback",
              "type": "boolean",
              "value": "={{ $(\"Triagem Backend\").first().json.fallback }}"
            }
          ]
        },
        "options": {}
      },
      "id": "7",
      "name": "Preparar Registro Lead",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [930, 300]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict",
                  "version": 2
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.intent }}",
                    "rightValue": "vendas",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "vendas"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict",
                  "version": 2
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.intent }}",
                    "rightValue": "suporte",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "suporte"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict",
                  "version": 2
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.intent }}",
                    "rightValue": "spam",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "spam"
            }
          ]
        },
        "options": {}
      },
      "id": "4",
      "name": "Switch Intent",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [1170, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://httpbin.org/post",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"pipeline\": \"hubspot-mock\", \"nome\": $json.nome, \"email\": $json.email, \"mensagem\": $json.mensagem, \"intent\": $json.intent, \"sentiment\": $json.sentiment, \"fallback\": $json.fallback } }}",
        "options": {}
      },
      "id": "5",
      "name": "HubSpot Mock",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1420, 220]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL + \"/rest/v1/lead_records\" }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.SUPABASE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "={{ \"Bearer \" + $env.SUPABASE_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "return=minimal"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json }}",
        "options": {}
      },
      "id": "6",
      "name": "Supabase Insert Lead",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1420, 380]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "name": "status",
              "type": "string",
              "value": "spam_ignorado"
            },
            {
              "name": "email",
              "type": "string",
              "value": "={{ $json.email }}"
            },
            {
              "name": "intent",
              "type": "string",
              "value": "={{ $json.intent }}"
            }
          ]
        },
        "options": {}
      },
      "id": "8",
      "name": "Spam Ignorado",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1420, 520]
    }
