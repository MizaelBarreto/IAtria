{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "web": {
      "entrypoint": ".",
      "framework": "nextjs",
      "routePrefix": "/"
    },
    "api": {
      "entrypoint": "backend/main.py",
      "framework": "fastapi",
      "routePrefix": "/backend",
      "memory": 1024,
      "maxDuration": 60,
      "excludeFiles": [
        "app/**",
        "components/**",
        "n8n/**",
        ".next/**",
        "node_modules/**",
        "fluxograma_tobe.drawio",
        "README.md"
      ]
    }
  }
}
